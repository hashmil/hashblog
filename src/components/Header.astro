---
// No logo import needed - using public folder
// No props needed for now
---

<header class="sticky top-0 z-40 bg-dark/80 backdrop-blur-md border-b border-gray-800">
  <div class="container py-4">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center justify-between w-full">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center group hover:opacity-80 transition-opacity duration-200">
          <img src="/images/logo.png" alt="Notes by Hash Milhan" class="h-8 object-contain" />
        </a>
      </div>
      
      <!-- Menu Button -->
      <div class="flex-shrink-0">
        <button 
          id="menu-button"
          class="flex items-center space-x-2 text-white hover:text-accent transition-colors duration-200"
          aria-label="Open menu"
          aria-controls="site-menu"
          aria-expanded="false"
        >
          <span class="font-accent">Menu</span>
          <div class="flex flex-col space-y-1">
            <div class="w-4 h-0.5 bg-current"></div>
            <div class="w-4 h-0.5 bg-current"></div>
            <div class="w-4 h-0.5 bg-current"></div>
          </div>
        </button>
      </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Native click events cover pointer, touch and keyboard activation.
  function initMenuButton() {
    const menuButton = document.getElementById('menu-button');
    if (!menuButton || menuButton.dataset.menuInitialised === 'true') return;

    menuButton.dataset.menuInitialised = 'true';
    menuButton.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('toggle-menu'));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMenuButton, { once: true });
  } else {
    initMenuButton();
  }
</script> 
